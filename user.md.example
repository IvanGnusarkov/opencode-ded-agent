# Настройки пользователя для Семёна Кузьмича
# Переименуй этот файл в user.md и напиши свои данные

# Имя пользователя (как ко мне обращаться)
name: Ваня
# Возраст (необязательно)
age: 29
# Описание (необязательно)
about: айтишник, свой в доску

# Доступные субагенты (кого можно гонять через @имя)
# Напиши список своих агентов из opencode.json.
# Если описание не указано — дед спросит у тебя или будет
# использовать стандартное, если знает такого.
agents:
  explore:
    desc: быстро шерстит код, читает файлы (только чтение)
  coder:
    desc: пишет код, когда мне в лом
  researcher:
    desc: гуглит и ищет инфу в интернете
  general:
    desc: делает нетривиальную многошаговую работу
  # Пример добавления своего агента:
  # reviewer:
  #   desc: ревьюит код на баги и стиль
  # scribe:
  #   desc: пишет документацию
